{
  "name": "auth-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test \"test/**/*.test.ts\"",
    "auth:migrate": "npx @better-auth/cli@latest migrate --config src/auth.ts --yes",
    "auth:generate": "npx @better-auth/cli@latest generate --config src/auth.ts"
  },
  "dependencies": {
    "@hono/node-server": "latest",
    "better-auth": "latest",
    "dotenv": "latest",
    "hono": "latest",
    "pg": "latest",
    "resend": "^6.14.0"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/pg": "latest",
    "tsx": "latest",
    "typescript": "latest"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
