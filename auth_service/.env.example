# PostgreSQL connection string. Use sslmode=require for many managed Postgres providers.
DATABASE_URL="postgresql://app:app@localhost:55432/app?sslmode=disable"

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-at-least-32-random-characters"

# Public base URL of this auth service. In development this usually matches PORT.
BETTER_AUTH_URL="http://localhost:3000"
PORT="3000"
NODE_ENV="development"

# Comma-separated browser/app origins allowed to call this auth service.
# Include frontend dev URLs and production app URLs. BETTER_AUTH_URL is added automatically.
TRUSTED_ORIGINS="http://localhost:5173,http://localhost:3000"

# Optional: enable Google sign-in when both values are present.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional until the public beta request form is enabled. Required to send approval emails.
RESEND_API_KEY=""
# Must use a verified Resend sending domain in production.
BETA_REQUEST_FROM="Agentic Engineering <onboarding@resend.dev>"
BETA_REQUEST_ADMIN_EMAIL="brian.oliveira100@gmail.com"
# Public auth-service origin used to build approve/decline links.
BETA_REQUEST_APPROVAL_BASE_URL="http://localhost:3000"
