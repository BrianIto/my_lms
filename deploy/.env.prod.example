# Copy to deploy/.env.prod on the VPS. Do not commit the real file.

# Domains
FRONTEND_HOST=learning.brianito.com
API_HOST=api.brianito.com
AUTH_HOST=auth.brianito.com

# Existing Traefik Docker network name. Create/join this network on the VPS.
TRAEFIK_NETWORK=traefik-public
TRAEFIK_CERT_RESOLVER=letsencrypt
TRAEFIK_ACME_EMAIL=contact@brianito.com

# App runtime
ENV=production
NODE_ENV=production
HTTP_ADDR=:8080
AUTH_PORT=3000
SHUTDOWN_TIMEOUT=10s

# Generate with: openssl rand -hex 32
# Keep URL-safe because Docker Compose embeds this value in DATABASE_URL.
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=replace-with-secure-random-hex-password
DATABASE_SCHEMA=public

# Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=

# Backend-to-auth service URL. In Docker Compose production this must use
# the internal service DNS name, not localhost and not the browser URL.
AUTH_SERVICE_URL=http://auth:3000

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4317
OTEL_SERVICE_NAME=lms-backend
OTEL_AUTH_SERVICE_NAME=lms-auth

# Better Auth. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=https://auth.brianito.com
TRUSTED_ORIGINS=https://learning.brianito.com,https://api.brianito.com,https://auth.brianito.com

# Frontend/backend allowed origins
WS_ALLOWED_ORIGINS=https://learning.brianito.com,https://auth.brianito.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Beta request emails via Resend
RESEND_API_KEY=
BETA_REQUEST_FROM="Brianito Learning <noreply@brianito.com>"
BETA_REQUEST_ADMIN_EMAIL=contact@brianito.com
BETA_REQUEST_APPROVAL_BASE_URL=https://auth.brianito.com

# Local Grafana, bound to VPS localhost only
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-secure-random-password
